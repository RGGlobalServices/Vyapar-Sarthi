{
  "name": "vyapar-sarthi",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "npx dotenv-cli -e .env.local -- cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 3000",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "test:e2e": "playwright test",
    "mobile:init": "npx cap init",
    "mobile:add": "npx cap add android",
    "mobile:assets": "capacitor-assets generate",
    "mobile:sync": "npx cap sync",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:open": "npx cap open android",
    "desktop:start": "electron .",
    "desktop:build": "electron-builder --win",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.36",
    "@google/genai": "^1.17.0",
    "@opentelemetry/api": "^1.6.0",
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.108.2",
    "@swc/core": "^1.15.30",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.4.2",
    "html2canvas-pro": "^2.0.2",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jsonrepair": "^3.14.0",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.553.0",
    "next": "^15.5.15",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.0",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.3",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.21.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "sharp": "^0.35.2",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jsbarcode": "^3.11.4",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^8.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "^15.5.15",
    "husky": "^9.1.7",
    "prisma": "^6.5.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.vyaparsarthi.app",
    "productName": "Vyapar Sarthi",
    "npmRebuild": false,
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
