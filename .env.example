# ── Vyapar Sarthi — App (UI + API) environment ──
# The app serves both the dashboard and the API (/api/v1/*) from one Next.js
# server. The landing page is a SEPARATE repository/deployment.
# Copy to .env.local for local dev; set these in your host's env for production.

# === Database (Supabase / PostgreSQL) ===
# On constrained/managed hosting (e.g. Hostinger Node) use the Supabase POOLER
# (port 6543) with a low connection_limit. This avoids the Prisma engine panic
# "PANIC: timer has gone away" that occurs when too many connections / cold-start
# races hit the query engine on a throttled container.
#   postgresql://postgres.<ref>:<pwd>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20&connect_timeout=15
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true&connection_limit=1&pool_timeout=20&connect_timeout=15"

# === Port ===
PORT=3000

# === Auth ===
SECRET_KEY="your-jwt-secret"
ADMIN_SECRET_KEY="your-admin-secret"

# === URLs ===
# App serves its own API at the same origin → relative is fine locally & in prod.
NEXT_PUBLIC_API_URL="/api/v1"
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_LANDING_URL="http://localhost:3001"
# Server-side (CORS allow-list, links, emails)
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
LANDING_URL="http://localhost:3001"

# === AI assistant ===
# OpenRouter powers the AI assistant — https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="nvidia/nemotron-3-nano-30b-a3b:free"
GEMINI_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# === SMTP (optional) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SUPPORT_EMAIL=""

# === PayU (subscriptions, optional) ===
PAYU_KEY=""
PAYU_SALT=""

# === Subscription cron ===
# Guards /api/v1/cron/process-subscriptions. Set a long random value and run a
# daily GET with header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# === Supabase storage (optional) ===
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
