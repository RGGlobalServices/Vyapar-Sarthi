# === Database ===
DATABASE_URL="postgresql://user:password@host:5432/database"

# === Backend (Node.js) ===
PORT=10000
SECRET_KEY="your-jwt-secret"
BACKEND_URL="http://localhost:10000"
NEXT_PUBLIC_API_URL="http://localhost:10000/api/v1"
ADMIN_SECRET_KEY="your-admin-secret"

# === Frontend (Next.js) ===
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# === Landing Page ===
LANDING_URL="http://localhost:3001"
NEXT_PUBLIC_LANDING_URL="http://localhost:3001"

# === Auth / APIs ===
# OpenRouter powers the AI assistant — https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="nvidia/nemotron-3-nano-30b-a3b:free"
GEMINI_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# === SMTP (optional) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SUPPORT_EMAIL=""

# === PayU (optional) ===
# For auto-debit/recurring (Standing Instruction), your PayU merchant account
# must have SI/Recurring enabled. Real debits + webhooks require a public HTTPS
# deployment — they cannot run against localhost.
PAYU_KEY=""
PAYU_SALT=""

# === Subscription cron ===
# Secret guarding /api/v1/cron/process-subscriptions. Set a long random value
# and configure a daily scheduler (Vercel Cron / Render Cron / cron-job.org) to
# GET that URL with header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# === Supabase (optional) ===
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
