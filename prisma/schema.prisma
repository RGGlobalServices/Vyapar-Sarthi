generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

model User {
  id                  Int           @id @default(autoincrement())
  uuid                String?       @unique @db.Uuid
  email               String        @unique @db.VarChar
  name                String        @default("") @db.VarChar
  mobile              String?       @db.VarChar
  password            String        @db.VarChar
  storeName           String?       @map("store_name") @db.VarChar
  businessType        String?       @map("business_type") @db.VarChar
  createdAt           DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  fullName            String?       @map("full_name") @db.VarChar
  isActive            Int?          @default(1) @map("is_active")
  passwordResetToken  String?       @map("password_reset_token") @db.VarChar
  passwordResetExpiry DateTime?     @map("password_reset_expiry") @db.Timestamptz(6)
  profitViewPassword  String?       @map("profit_view_password") @db.VarChar
  adminPin            String?       @map("admin_pin") @db.VarChar
  maxShops            Int?          @map("max_shops")
  toolUsages          ToolUsage[]
  sessions            UserSession[]

  @@map("users")
}

model ToolUsage {
  id       String   @id @default(uuid()) @db.Uuid
  userId   Int      @map("user_id")
  tool     String   @db.VarChar
  count    Int      @default(1)
  lastUsed DateTime @default(now()) @map("last_used") @db.Timestamptz(6)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, tool])
  @@map("tool_usage")
}

model UserSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    Int      @map("user_id")
  device    String   @db.VarChar
  os        String   @db.VarChar
  browser   String   @db.VarChar
  ip        String   @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeen  DateTime @default(now()) @map("last_seen") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Shop {
  id                      String               @id @default(uuid()) @db.Uuid
  ownerId                 String?              @map("owner_id") @db.Uuid
  name                    String?              @db.VarChar
  address                 String?              @db.VarChar
  createdAt               DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  businessType            String?              @default("kirana") @map("business_type") @db.VarChar
  setupComplete           Boolean?             @default(false) @map("setup_complete")
  mobile                  String?
  logoUrl                 String?              @map("logo_url")
  shopCode                String?              @unique @map("shop_code") @db.VarChar
  packageType             String?              @default("dukan") @map("package_type") @db.VarChar
  subscriptionPlan        String?              @default("trial") @map("subscription_plan") @db.VarChar
  subscriptionStatus      String?              @default("active") @map("subscription_status") @db.VarChar
  subscriptionExpiry      DateTime?            @map("subscription_expiry") @db.Timestamptz(6)
  subscriptionCancelledAt DateTime?            @map("subscription_cancelled_at") @db.Timestamptz(6)
  cancellationReason      String?              @map("cancellation_reason")
  // Free trial + auto-debit (PayU Standing Instruction / eMandate)
  subscriptionTrialEnds   DateTime?            @map("subscription_trial_ends") @db.Timestamptz(6)
  trialPaused             Boolean?             @default(false) @map("trial_paused")
  trialPauseStart         DateTime?            @map("trial_pause_start") @db.Timestamptz(6)
  mandateToken            String?              @map("mandate_token") @db.VarChar
  mandateStatus           String?              @map("mandate_status") @db.VarChar
  nextBillingDate         DateTime?            @map("next_billing_date") @db.Timestamptz(6)
  billingAmount           Float?               @map("billing_amount")
  lastTxnId               String?              @map("last_txn_id") @db.VarChar
  firstChargeDate         DateTime?            @map("first_charge_date") @db.Timestamptz(6)
  gst                     String?              @db.VarChar
  pan                     String?              @db.VarChar
  invoiceFormat           String?              @default("thermal80") @map("invoice_format") @db.VarChar
  invoiceFooter           String?              @map("invoice_footer")
  showQrCode              Boolean?             @default(false) @map("show_qr_code")
  
  customers               Customer[]
  products                Product[]
  sales                   Sale[]
  stockLogs               StockLog[]
  godowns                 Godown[]
  paymentTransactions     PaymentTransaction[]
  materialReturns         MaterialReturn[]
  staff                   Staff[]
  suppliers               Supplier[]
  purchaseInvoices        PurchaseInvoice[]
  batches                 Batch[]
  expenses                Expense[]
  orders                  Order[]
  categories              Category[]
  brands                  Brand[]
  units                   Unit[]
  expenseCategories       ExpenseCategory[]
  cashBooks               CashBook[]
  dailyClosings           DailyClosing[]
  activityLogs            ActivityLog[]
  importLogs              ImportLog[]

  @@index([name], map: "ix_shops_name")
  @@index([ownerId], map: "ix_shops_owner_id")
  @@map("shops")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @map("shop_id") @db.Uuid
  category    String   @db.VarChar
  amount      Float
  date        DateTime @default(now()) @db.Timestamptz(6)
  description String?  @db.VarChar
  paymentMode   String?  @map("payment_mode") @db.VarChar
  attachmentUrl String?  @map("attachment_url") @db.VarChar
  isRecurring   Boolean? @default(false) @map("is_recurring")
  warehouseId   String?  @map("warehouse_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, date(sort: Desc)], map: "ix_expenses_shop_date")
  @@index([shopId, category], map: "ix_expenses_shop_category")
  @@map("expenses")
}

model Order {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @map("shop_id") @db.Uuid
  orderNumber String   @map("order_number") @db.VarChar
  customerId  String?  @map("customer_id") @db.Uuid
  totalAmount Float    @map("total_amount")
  status      String   @default("pending") @db.VarChar
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction)

  @@index([shopId])
  @@index([customerId])
  @@map("orders")
}

model PaymentTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  shopId       String   @map("shop_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  txnid        String   @db.VarChar
  mihpayid     String?  @db.VarChar
  plan         String?  @db.VarChar
  amount       Float
  // mandate_registration | recurring | trial | refund
  type         String   @db.VarChar
  // success | failed | pending | refunded
  status       String   @db.VarChar
  mode         String?  @db.VarChar
  payuResponse String?  @map("payu_response") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([txnid])
  @@map("payment_transactions")
}

model Product {
  id               String           @id @default(uuid()) @db.Uuid
  shopId           String?          @map("shop_id") @db.Uuid
  name             String?          @db.VarChar
  category         String?          @db.VarChar
  baseUnit         String?          @map("base_unit") @db.VarChar
  mrp              Float?
  sellingPrice     Float?           @map("selling_price")
  wholesaleCost    Float?           @map("wholesale_cost")
  conversionFactor Float?           @map("conversion_factor")
  minStock         Float?           @map("min_stock")
  currentStock     Float?           @map("current_stock")
  barcode          String?          @unique(map: "ix_products_barcode") @db.VarChar
  expiryDate       String?          @map("expiry_date") @db.VarChar
  batch_number     String?          @db.VarChar
  drug_schedule    String?          @db.VarChar
  model_number     String?          @db.VarChar
  warranty_months  Int?
  gender           String?          @db.VarChar
  size_variants    String?
  shade            String?          @db.VarChar
  archived         Boolean?         @default(false)
  is_loose         Boolean?         @default(false)
  metadata         Json?            @default("{}")
  variants         Json?            @default("[]")
  brand            String?          @db.VarChar
  hsnCode          String?          @map("hsn_code") @db.VarChar
  productType      String?          @default("single") @map("product_type") @db.VarChar
  gstPercent       Float?           @map("gst_percent")
  shop             Shop?            @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  saleItems        SaleItem[]
  stock_logs       StockLog[]
  godownProducts   GodownProduct[]
  materialReturns  MaterialReturn[]
  returnItems      ReturnItem[]
  productVariants  ProductVariant[]
  batches          Batch[]
  purchaseItems    PurchaseItem[]

  // --- New Master Data Relational Fields ---
  categoryId            String?          @map("category_id") @db.Uuid
  brandId               String?          @map("brand_id") @db.Uuid
  baseUnitId            String?          @map("base_unit_id") @db.Uuid
  defaultSaleUnitId     String?          @map("default_sale_unit_id") @db.Uuid
  defaultPurchaseUnitId String?          @map("default_purchase_unit_id") @db.Uuid
  maxStock              Float?           @map("max_stock")
  wholesaleMoq          Float?           @map("wholesale_moq")

  masterCategory        Category?        @relation(fields: [categoryId], references: [id], onDelete: NoAction)
  masterBrand           Brand?           @relation(fields: [brandId], references: [id], onDelete: NoAction)
  masterBaseUnit        Unit?            @relation("ProductBaseUnit", fields: [baseUnitId], references: [id], onDelete: NoAction)
  masterSaleUnit        Unit?            @relation("ProductSaleUnit", fields: [defaultSaleUnitId], references: [id], onDelete: NoAction)
  masterPurchaseUnit    Unit?            @relation("ProductPurchaseUnit", fields: [defaultPurchaseUnitId], references: [id], onDelete: NoAction)

  @@index([category], map: "ix_products_category")
  @@index([name], map: "ix_products_name")
  @@index([shopId], map: "ix_products_shop_id")
  @@index([shopId, barcode], map: "ix_products_shop_barcode")
  @@index([shopId, category], map: "ix_products_shop_category")
  @@index([shopId, name], map: "ix_products_shop_name")
  @@index([categoryId], map: "ix_products_category_id")
  @@index([brandId], map: "ix_products_brand_id")
  @@index([baseUnitId], map: "ix_products_base_unit_id")
  @@index([shopId, archived], map: "ix_products_shop_archived")
  @@map("products")
}

model Customer {
  id                    String                  @id @default(uuid()) @db.Uuid
  shopId                String?                 @map("shop_id") @db.Uuid
  name                  String?                 @db.VarChar
  mobile                String?                 @db.VarChar
  email                 String?                 @db.VarChar
  totalDue              Float?                  @map("total_due")
  
  // CRM Extended Fields
  customerType          String?                 @default("customer") @map("customer_type") @db.VarChar
  shopName              String?                 @map("shop_name") @db.VarChar
  gst                   String?                 @db.VarChar
  pan                   String?                 @db.VarChar
  address               String?                 @db.VarChar
  creditDays            Int?                    @default(0) @map("credit_days")
  creditLimit           Float?                  @default(0) @map("credit_limit")
  birthday              DateTime?               @db.Date
  notes                 String?                 @db.VarChar
  createdAt             DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  customer_transactions customer_transactions[]
  shop                  Shop?                   @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales                 Sale[]
  orders                Order[]

  @@index([mobile], map: "ix_customers_mobile")
  @@index([name], map: "ix_customers_name")
  @@index([shopId], map: "ix_customers_shop_id")
  @@index([shopId, mobile], map: "ix_customers_shop_mobile")
  @@index([shopId, name], map: "ix_customers_shop_name")
  @@index([shopId, totalDue(sort: Desc)], map: "ix_customers_shop_totaldue")
  @@map("customers")
}

model Sale {
  id             String     @id @default(uuid()) @db.Uuid
  shopId         String?    @map("shop_id") @db.Uuid
  customerId     String?    @map("customer_id") @db.Uuid
  totalAmount    Float?     @map("total_amount")
  totalProfit    Float?     @map("total_profit")
  paymentType    String?    @map("payment_type") @db.VarChar
  amountPaid     Float?     @default(0) @map("amount_paid")
  paymentDetails Json?      @default("{}") @map("payment_details")
  createdAt      DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  invoice_number String?    @unique @db.VarChar
  // GST / Non-GST billing. billType: 'gst' | 'non_gst' (default non_gst).
  // gstDetails holds the tax breakdown { taxable, cgst, sgst, igst, rate, interState }.
  billType       String?    @default("non_gst") @map("bill_type") @db.VarChar
  gstAmount      Float?     @map("gst_amount")
  gstDetails     Json?      @map("gst_details")
  // Manual bill upload: reference to the stored bill image/PDF and a manual flag.
  billImageUrl   String?    @map("bill_image_url") @db.VarChar
  isManual       Boolean?   @default(false) @map("is_manual")
  items          SaleItem[]
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop           Shop?      @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([shopId, createdAt(sort: Desc)], map: "ix_sales_shop_created")
  @@index([customerId], map: "ix_sales_customer_id")
  @@index([shopId, invoice_number], map: "ix_sales_shop_invoice")
  @@map("sales")
}

model SaleItem {
  id            String   @id @default(uuid()) @db.Uuid
  saleId        String?  @map("sale_id") @db.Uuid
  productId     String?  @map("product_id") @db.Uuid
  unit          String?  @db.VarChar
  quantity      Float?
  pricePerUnit  Float?   @map("price_per_unit")
  marginPerUnit Float?   @map("margin_per_unit")
  variant       String?  @db.VarChar
  variantId     String?  @map("variant_id") @db.VarChar
  product       Product? @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale          Sale?    @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([saleId], map: "ix_sale_items_sale_id")
  @@index([productId], map: "ix_sale_items_product_id")
  @@map("sale_items")
}

model StockLog {
  id        String    @id @default(uuid()) @db.Uuid
  shopId    String?   @map("shop_id") @db.Uuid
  productId String?   @map("product_id") @db.Uuid
  type      String?   @db.VarChar
  quantity  Float?
  note      String?   @db.VarChar
  variantId String?   @map("variant_id") @db.VarChar
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  products  Product?  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop      Shop?     @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([shopId, createdAt(sort: Desc)], map: "ix_stock_logs_shop_created")
  @@index([productId], map: "ix_stock_logs_product_id")
  @@index([shopId, type, createdAt(sort: Desc)], map: "ix_stock_logs_shop_type_created")
  @@map("stock_logs")
}

model PushSubscription {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  endpoint  String?   @unique(map: "ix_push_subscriptions_endpoint") @db.VarChar
  p256dh    String?   @db.VarChar
  auth      String?   @db.VarChar
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("push_subscriptions")
}

model NotificationSetting {
  userId               String   @id @map("user_id") @db.Uuid
  dailySummaryEnabled  Boolean? @map("daily_summary_enabled")
  lowStockAlertEnabled Boolean? @map("low_stock_alert_enabled")
  alertTime            String?  @map("alert_time") @db.VarChar
  udharWhatsAppEnabled Boolean? @map("udhar_whatsapp_enabled")
  udharEmailEnabled    Boolean? @map("udhar_email_enabled")

  @@map("notification_settings")
}

model UserNotification {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @map("user_id") @db.Uuid
  adminNotificationId String?            @map("admin_notification_id") @db.Uuid
  title               String             @db.VarChar
  message             String             @db.VarChar
  notificationType    String?            @map("notification_type") @db.VarChar
  isRead              Boolean?           @map("is_read")
  link                String?            @db.VarChar
  createdAt           DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  adminNotification   AdminNotification? @relation(fields: [adminNotificationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt(sort: Desc)], map: "user_notif_created_idx")
  @@index([userId, isRead], map: "user_notif_read_idx")
  @@index([userId], map: "user_notif_user_id_idx")
  @@map("user_notifications")
}

model AdminNotification {
  id                String             @id @default(uuid()) @db.Uuid
  adminId           String             @map("admin_id") @db.Uuid
  title             String             @db.VarChar
  message           String             @db.VarChar
  notificationType  String?            @map("notification_type") @db.VarChar
  targetAudience    String?            @map("target_audience") @db.VarChar
  targetPlan        String?            @map("target_plan") @db.VarChar
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  admin             AdminUser          @relation(fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userNotifications UserNotification[]

  @@index([adminId], map: "admin_notif_admin_idx")
  @@map("admin_notifications")
}

model ReferralCode {
  userId              String    @id @map("user_id") @db.Uuid
  code                String    @unique(map: "ix_referral_codes_code") @db.VarChar
  totalReferrals      Int?      @map("total_referrals")
  successfulReferrals Int?      @map("successful_referrals")
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([code])
  @@index([userId])
  @@map("referral_codes")
}

model Referral {
  id               String    @id @default(uuid()) @db.Uuid
  referrerId       String    @map("referrer_id") @db.Uuid
  referredId       String?   @map("referred_id") @db.Uuid
  referralCode     String    @map("referral_code") @db.VarChar
  referredEmail    String?   @map("referred_email") @db.VarChar
  status           String?   @db.VarChar
  discountApplied  Boolean?  @map("discount_applied")
  referrerRewarded Boolean?  @map("referrer_rewarded")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)

  @@index([referralCode], map: "ix_referrals_referral_code")
  @@index([referralCode], map: "referrals_code_idx")
  @@index([referredId])
  @@index([referrerId])
  @@map("referrals")
}

model SupportTicket {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  name         String    @db.VarChar
  email        String    @db.VarChar
  phone        String?   @db.VarChar
  shopName     String?   @map("shop_name") @db.VarChar
  type         String    @db.VarChar
  priority     String?   @db.VarChar
  subject      String?   @db.VarChar
  message      String    @db.VarChar
  status       String?   @db.VarChar
  adminNotes   String?   @map("admin_notes") @db.VarChar
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at   DateTime? @db.Timestamptz(6)
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)
  refundAmount String?   @map("refund_amount")
  refundReason String?   @map("refund_reason")
  txnId        String?   @map("txn_id")
  displayId    String?   @map("display_id") @db.VarChar(12)

  @@index([status], map: "tickets_status_idx")
  @@index([userId], map: "tickets_user_id_idx")
  @@map("support_tickets")
}

model DukandarRelationship {
  id           String               @id @default(uuid()) @db.Uuid
  wholesalerId String               @map("wholesaler_id") @db.Uuid
  retailerId   String               @map("retailer_id") @db.Uuid
  status       String?              @default("active") @db.VarChar
  createdAt    DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  alerts       DukandarStockAlert[]
  credits      DukandarCredit[]

  @@index([retailerId], map: "dukandar_retailer_idx")
  @@index([wholesalerId], map: "dukandar_wholesaler_idx")
  @@map("dukandar_relationships")
}

model DukandarStockAlert {
  id             String               @id @default(uuid()) @db.Uuid
  relationshipId String               @map("relationship_id") @db.Uuid
  wholesalerId   String               @map("wholesaler_id") @db.Uuid
  retailerId     String               @map("retailer_id") @db.Uuid
  message        String               @db.VarChar
  products       String               @db.VarChar
  status         String               @default("pending") @db.VarChar
  createdAt      DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  respondedAt    DateTime?            @map("responded_at") @db.Timestamptz(6)
  relationship   DukandarRelationship @relation(fields: [relationshipId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([retailerId])
  @@index([wholesalerId])
  @@index([relationshipId])
  @@map("dukandar_stock_alerts")
}

model DukandarCredit {
  id             String               @id @default(uuid()) @db.Uuid
  relationshipId String               @map("relationship_id") @db.Uuid
  wholesalerId   String               @map("wholesaler_id") @db.Uuid
  retailerId     String               @map("retailer_id") @db.Uuid
  amount         Float
  description    String?              @db.VarChar
  items          String               @db.VarChar
  status         String               @default("pending") @db.VarChar
  dueDate        DateTime?            @map("due_date") @db.Timestamptz(6)
  createdAt      DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt         DateTime?            @map("paid_at") @db.Timestamptz(6)
  relationship   DukandarRelationship @relation(fields: [relationshipId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wholesalerId])
  @@index([retailerId])
  @@index([relationshipId])
  @@map("dukandar_credits")
}

model AdminUser {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique(map: "ix_admin_users_email") @db.VarChar
  hashedPassword     String              @map("hashed_password") @db.VarChar
  fullName           String              @map("full_name") @db.VarChar
  role               String?             @db.VarChar
  isActive           Int?                @map("is_active")
  createdAt          DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  adminNotifications AdminNotification[]

  @@index([email])
  @@map("admin_users")
}

model Godown {
  id         String          @id @default(uuid()) @db.Uuid
  shopId     String          @map("shop_id") @db.Uuid
  ownerId    String          @map("owner_id") @db.Uuid
  name       String          @db.VarChar
  location   String?         @db.VarChar
  godownCode String          @unique @map("godown_code") @db.VarChar
  createdAt  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  shop       Shop            @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inventory  GodownProduct[]

  @@index([shopId])
  @@index([ownerId])
  @@map("godowns")
}

model ReturnItem {
  id            String  @id @default(uuid()) @db.Uuid
  returnId      String  @map("return_id") @db.Uuid
  productId     String  @map("product_id") @db.Uuid
  quantity      Int
  refundAmount  Float   @map("refund_amount")
  stockRestored Boolean @default(true) @map("stock_restored")

  materialReturn MaterialReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: NoAction)

  @@map("return_items")
}

model Staff {
  id               String   @id @default(uuid()) @db.Uuid
  shopId           String   @map("shop_id") @db.Uuid
  name             String   @db.VarChar
  mobile           String   @db.VarChar
  address          String?  @db.VarChar
  idProof          String?  @map("id_proof") @db.VarChar
  emergencyContact String?  @map("emergency_contact") @db.VarChar
  role             String   @default("Other") @db.VarChar
  joiningDate      DateTime @default(now()) @map("joining_date") @db.Timestamptz(6)
  salaryType       String   @default("monthly") @map("salary_type") @db.VarChar
  salaryAmount     Float    @map("salary_amount")
  bankAccount      Json?    @map("bank_account")
  documents        Json?    @default("{}")
  photoUrl         String?  @map("photo_url")
  status           String   @default("active") @db.VarChar
  warehouseId      String?  @map("warehouse_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  attendance     Attendance[]
  salaryPayments SalaryPayment[]
  advanceSalaries AdvanceSalary[]

  @@map("staff")
}

model Attendance {
  id      String   @id @default(uuid()) @db.Uuid
  staffId String   @map("staff_id") @db.Uuid
  date    DateTime @db.Date
  status  String   @db.VarChar
  reason  String?  @db.VarChar

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("attendance")
}

model SalaryPayment {
  id          String   @id @default(uuid()) @db.Uuid
  staffId     String   @map("staff_id") @db.Uuid
  monthYear   String   @map("month_year") @db.VarChar
  baseAmount  Float    @map("base_amount")
  deductions  Float    @default(0)
  bonus       String?
  netAmount   Float    @map("net_amount")
  paymentMode String   @default("Cash") @map("payment_mode") @db.VarChar
  paidAt      DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("salary_payments")
}

model GodownProduct {
  id        String   @id @default(uuid()) @db.Uuid
  godownId  String   @map("godown_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Float    @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  godown    Godown   @relation(fields: [godownId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([godownId, productId])
  @@index([godownId])
  @@index([productId])
  @@map("godown_products")
}

model customer_transactions {
  id          String    @id @default(uuid()) @db.Uuid
  customer_id String?   @db.Uuid
  type        String?   @db.VarChar
  amount      Float?
  note        String?   @db.VarChar
  bill_number String?   @db.VarChar
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  customers   Customer? @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customer_id])
}

model SupplierTransaction {
  id          String    @id @default(uuid()) @db.Uuid
  supplierId  String?   @map("supplier_id") @db.Uuid
  type        String?   @db.VarChar
  amount      Float?
  note        String?   @db.VarChar
  billNumber  String?   @map("bill_number") @db.VarChar
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([supplierId])
  @@map("supplier_transactions")
}

model CalendarEvent {
  id           String   @id @default(uuid()) @db.Uuid
  shopId       String   @map("shop_id") @db.Uuid
  ownerId      String?  @map("owner_id") @db.Uuid
  title        String   @db.VarChar
  description  String?  @db.VarChar
  eventDate    DateTime @map("event_date") @db.Timestamptz(6)
  eventType    String   @default("event") @map("event_type") @db.VarChar
  amount       Float?
  customerName String?  @map("customer_name") @db.VarChar
  status       String   @default("pending") @db.VarChar
  reminderDays Int      @default(1) @map("reminder_days")
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([shopId, eventDate])
  @@map("calendar_events")
}

model MaterialReturn {
  id          String       @id @default(uuid()) @db.Uuid
  shopId      String       @map("shop_id") @db.Uuid
  productId   String?      @map("product_id") @db.Uuid
  itemName    String?      @db.VarChar
  quantity    Float
  reason      String       @db.VarChar // e.g. "Damaged", "Wrong Item", "Defective", etc.
  note        String?      @db.VarChar
  amount      Float?
  date        DateTime?    @default(now()) @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product     Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  returnItems ReturnItem[]

  @@index([shopId])
  @@index([productId])
  @@map("material_returns")
}

model ProductVariant {
  id           String    @id @default(uuid()) @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  size         String?   @db.VarChar
  unit         String?   @db.VarChar
  barcode      String?   @unique @db.VarChar
  costPrice    Float?    @map("cost_price")
  sellingPrice Float?    @map("selling_price")
  mrp          Float?
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches       Batch[]
  purchaseItems PurchaseItem[]

  @@index([productId])
  @@map("product_variants")
}

model Supplier {
  id        String    @id @default(uuid()) @db.Uuid
  shopId    String    @map("shop_id") @db.Uuid
  name      String    @db.VarChar
  contact   String?   @db.VarChar
  mobile    String?   @db.VarChar
  email     String?   @db.VarChar
  address   String?   @db.VarChar
  gst       String?   @db.VarChar
  balance   Float     @default(0)
  creditDays  Int?    @default(0) @map("credit_days")
  creditLimit Float?  @default(0) @map("credit_limit")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchaseInvoices     PurchaseInvoice[]
  supplierTransactions SupplierTransaction[]

  @@index([shopId])
  @@map("suppliers")
}

model PurchaseInvoice {
  id            String    @id @default(uuid()) @db.Uuid
  shopId        String    @map("shop_id") @db.Uuid
  supplierId    String    @map("supplier_id") @db.Uuid
  invoiceNumber String?   @map("invoice_number") @db.VarChar
  date          DateTime? @default(now()) @db.Timestamptz(6)
  totalCost     Float?    @map("total_cost")
  gst           Float?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]

  @@index([shopId])
  @@index([supplierId])
  @@map("purchase_invoices")
}

model PurchaseItem {
  id                String  @id @default(uuid()) @db.Uuid
  purchaseInvoiceId String  @map("purchase_invoice_id") @db.Uuid
  productId         String  @map("product_id") @db.Uuid
  variantId         String? @map("variant_id") @db.Uuid
  quantity          Float
  cost              Float
  gst               Float?

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([purchaseInvoiceId])
  @@index([productId])
  @@map("purchase_items")
}

model Batch {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @map("shop_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  variantId   String?   @map("variant_id") @db.Uuid
  batchNumber String?   @map("batch_number") @db.VarChar
  mfgDate     DateTime? @map("mfg_date") @db.Timestamptz(6)
  expiryDate  DateTime? @map("expiry_date") @db.Timestamptz(6)
  quantity    Float     @default(0)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([productId])
  @@map("batches")
}

model StockMovement {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @map("shop_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  variantId   String?   @map("variant_id") @db.Uuid
  warehouseId String?   @map("warehouse_id") @db.Uuid
  type        String    @db.VarChar // purchase, sale, return, adjustment, transfer
  quantity    Float
  referenceId String?   @map("reference_id") @db.Uuid
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([shopId])
  @@index([productId])
  @@map("stock_movements")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  shopId    String    @map("shop_id") @db.Uuid
  name      String    @db.VarChar
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop     Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("SubCategories")
  products Product[]

  @@index([shopId])
  @@index([parentId])
  @@map("categories")
}

model Brand {
  id           String    @id @default(uuid()) @db.Uuid
  shopId       String    @map("shop_id") @db.Uuid
  name         String    @db.VarChar
  manufacturer Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([shopId])
  @@map("brands")
}

model Unit {
  id               String    @id @default(uuid()) @db.Uuid
  shopId           String    @map("shop_id") @db.Uuid
  name             String    @db.VarChar
  shortName        String    @map("short_name") @db.VarChar
  baseUnitId       String?   @map("base_unit_id") @db.Uuid
  conversionFactor Float?    @default(1) @map("conversion_factor")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  baseUnit          Unit?     @relation("UnitConversions", fields: [baseUnitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  derivedUnits      Unit[]    @relation("UnitConversions")
  productsBase      Product[] @relation("ProductBaseUnit")
  productsSale      Product[] @relation("ProductSaleUnit")
  productsPurchase  Product[] @relation("ProductPurchaseUnit")

  @@index([baseUnitId])
  @@map("units")
}

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  name      String   @db.VarChar
  type      String   @default("custom") @db.VarChar // "system" or "custom"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("expense_categories")
}

model AdvanceSalary {
  id                   String   @id @default(uuid()) @db.Uuid
  staffId              String   @map("staff_id") @db.Uuid
  date                 DateTime @default(now()) @db.Timestamptz(6)
  amount               Float
  deducted             Boolean  @default(false)
  deductedFromSalaryId String?  @map("deducted_from_salary_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("advance_salaries")
}

model CashBook {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @map("shop_id") @db.Uuid
  date        DateTime @default(now()) @db.Timestamptz(6)
  type        String   @db.VarChar // sale, purchase, expense, collection, withdrawal, opening_balance, deposit
  amount      Float
  referenceId String?  @map("reference_id") @db.Uuid
  description String?  @db.VarChar
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, date(sort: Desc)])
  @@index([shopId, type, date(sort: Desc)], map: "ix_cash_books_shop_type_date")
  @@map("cash_books")
}

model DailyClosing {
  id             String   @id @default(uuid()) @db.Uuid
  shopId         String   @map("shop_id") @db.Uuid
  date           DateTime @db.Date
  openingCash    Float    @default(0) @map("opening_cash")
  cashSales      Float    @default(0) @map("cash_sales")
  cashCollection Float    @default(0) @map("cash_collection")
  cashExpenses   Float    @default(0) @map("cash_expenses")
  cashDeposits   Float    @default(0) @map("cash_deposits")
  closingCash    Float    @default(0) @map("closing_cash")
  difference     Float    @default(0)
  closedBy       String?  @map("closed_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@map("daily_closings")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar // e.g. "expense_added", "staff_added", "daily_closed"
  entityId  String?  @map("entity_id") @db.Uuid
  details   Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ─── Import Log ──────────────────────────────────────────────────────────────
// Tracks every AI-import session: who, when, how many rows succeeded/failed.

model ImportLog {
  id            String    @id @default(uuid()) @db.Uuid
  shopId        String    @map("shop_id") @db.Uuid
  importName    String    @map("import_name") @db.VarChar
  fileName      String?   @map("file_name") @db.VarChar
  source        String    @db.VarChar // 'stock' | 'purchase' | 'mixed'
  totalRows     Int       @map("total_rows")
  importedCount Int       @default(0) @map("imported_count")
  updatedCount  Int       @default(0) @map("updated_count")
  skippedCount  Int       @default(0) @map("skipped_count")
  failedCount   Int       @default(0) @map("failed_count")
  errors        Json?     @default("[]")
  processingMs  Int?      @map("processing_ms")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt(sort: Desc)])
  @@map("import_logs")
}
